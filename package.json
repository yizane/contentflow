    "db:migrate": "node scripts/tools/db_migrate.js",
    "db:list": "node scripts/tools/db_list.js",
    "db:show": "node scripts/tools/db_show.js",
    "engine:daily": "node scripts/engine_daily.js",
    "engine:batch": "node scripts/engine_batch.js",
    "engine:report": "node scripts/engine_report.js",
    "sources:collect": "node scripts/pipeline/sources_collect.js",
    "sources:check": "node scripts/tools/sources_check.js",
    "sources:fix": "node scripts/pipeline/sources_fix.js",
    "sources:resolve": "node scripts/pipeline/sources_resolve.js",
    "topics:generate": "node scripts/pipeline/topics_generate.js",
    "jobs:create": "node scripts/pipeline/jobs_create.js",
    "jobs:run": "node scripts/pipeline/jobs_run.js",
