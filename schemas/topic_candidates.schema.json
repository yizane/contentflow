{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "flyfus-content-agent/topic_candidates.schema.json",
  "title": "Flyfus Topic Candidates Output",
  "type": "object",
  "additionalProperties": false,
  "required": ["generatedAt", "candidates"],
  "properties": {
    "generatedAt": { "type": "string" },
    "candidates": {
      "type": "array",
      "minItems": 5,
      "maxItems": 40,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["topic", "primaryKeyword", "secondaryKeywords", "category", "contentAngle", "businessAngle", "sourceUrls", "score", "priority", "status", "reason", "rejectRisk"],
        "properties": {
          "topic": { "type": "string", "minLength": 8 },
          "primaryKeyword": { "type": "string", "minLength": 2 },
          "secondaryKeywords": { "type": "array", "items": { "type": "string" } },
          "category": {
            "type": "string",
            "enum": ["rufus", "listing-geo", "product-research", "ppc-acos", "keyword", "ai-search-ops"]
          },
          "contentAngle": { "type": "string", "minLength": 4 },
          "businessAngle": { "type": "string", "minLength": 2 },
          "sourceUrls": { "type": "array", "items": { "type": "string", "pattern": "^https?://" }, "maxItems": 6 },
          "score": { "type": "number", "minimum": 0, "maximum": 100 },
          "priority": { "type": "string", "enum": ["P0", "P1", "P2"] },
          "status": { "type": "string", "enum": ["candidate"] },
          "reason": { "type": "string" },
          "rejectRisk": { "type": "string" }
        }
      }
    }
  }
}
