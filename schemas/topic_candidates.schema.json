{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "flyfus-content-agent/topic_candidates.schema.json",
  "title": "Flyfus Topic Candidates Output",
  "type": "object",
  "additionalProperties": false,
  "required": ["generatedAt", "candidates"],
  "properties": {
    "generatedAt": { "type": "string" },
    "candidates": {
      "type": "array",
      "minItems": 5,
      "maxItems": 40,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["topic", "primaryKeyword", "secondaryKeywords", "category", "contentAngle", "businessAngle", "sourceUrls", "score", "priority", "status", "reason", "rejectRisk", "contentType", "businessCategory", "topicCluster", "contentValueScore", "sellerPainValue", "actionability", "informationGain", "businessFit", "nonRepetition", "sourceSupport"],
        "properties": {
          "topic": { "type": "string", "minLength": 8 },
          "primaryKeyword": { "type": "string", "minLength": 2 },
          "secondaryKeywords": { "type": "array", "items": { "type": "string" } },
          "category": {
            "type": "string",
            "enum": ["rufus", "listing-geo", "product-research", "ppc-acos", "keyword", "ai-search-ops"]
          },
          "contentType": {
            "type": "string",
            "description": "内容形态，取 content_taxonomy 的 content_types 枚举 key",
            "enum": ["news_flash", "policy_update", "operation_guide", "product_update", "market_report", "trend_analysis", "case_study", "tool_review", "risk_warning", "qa_discussion"]
          },
          "businessCategory": {
            "type": "string",
            "description": "业务主题，取 content_taxonomy 的 business_categories 枚举 key",
            "enum": ["amazon_ai_shopping", "listing_geo", "product_research", "ppc_acos", "keyword_intent", "review_qa", "account_compliance", "fba_inventory", "brand_growth", "marketplace_policy", "ai_tools"]
          },
          "topicCluster": {
            "type": "string",
            "description": "主题簇（可空字符串），须与 businessCategory 一致",
            "enum": ["alexa_for_shopping_listing", "listing_semantic_structure", "rufus_question_data", "ppc_intent_keywords", "product_opportunity_mining", "compliance_risk_warning", ""]
          },
          "contentAngle": { "type": "string", "minLength": 4 },
          "businessAngle": { "type": "string", "minLength": 2 },
          "sourceUrls": { "type": "array", "items": { "type": "string", "pattern": "^https?://" }, "maxItems": 6 },
          "score": { "type": "number", "minimum": 0, "maximum": 100 },
          "contentValueScore": { "type": "number", "minimum": 0, "maximum": 100, "description": "内容价值分 = 六个细项之和，SEO/GEO 不参与" },
          "sellerPainValue": { "type": "number", "minimum": 0, "maximum": 20 },
          "actionability": { "type": "number", "minimum": 0, "maximum": 20 },
          "informationGain": { "type": "number", "minimum": 0, "maximum": 20 },
          "businessFit": { "type": "number", "minimum": 0, "maximum": 15 },
          "nonRepetition": { "type": "number", "minimum": 0, "maximum": 15 },
          "sourceSupport": { "type": "number", "minimum": 0, "maximum": 10 },
          "priority": { "type": "string", "enum": ["P0", "P1", "P2"] },
          "status": { "type": "string", "enum": ["candidate"] },
          "reason": { "type": "string" },
          "rejectRisk": { "type": "string" }
        }
      }
    }
  }
}
