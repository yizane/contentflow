{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "flyfus-content-agent/article.schema.json",
  "title": "Flyfus Article Output",
  "description": "OpenClaw Agent 生成文章的输出契约。只允许列出的字段，全部必填。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "articleTitle",
    "slug",
    "metaTitle",
    "metaDescription",
    "category",
    "tags",
    "primaryKeyword",
    "secondaryKeywords",
    "articleMarkdown",
    "faqJson",
    "schemaJsonLd",
    "sources",
    "internalLinks",
    "flyfusCta"
  ],
  "properties": {
    "articleTitle": {
      "type": "string",
      "minLength": 8,
      "description": "文章 H1 标题，含主关键词"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "maxLength": 80,
      "description": "英文小写连字符 slug"
    },
    "metaTitle": {
      "type": "string",
      "minLength": 8,
      "maxLength": 70,
      "description": "SEO meta title，中文建议 ≤ 30 个汉字"
    },
    "metaDescription": {
      "type": "string",
      "minLength": 40,
      "maxLength": 220,
      "description": "SEO meta description，中文建议 70-90 个汉字，含主关键词"
    },
    "category": {
      "type": "string",
      "enum": ["rufus", "listing-geo", "product-research", "ppc-acos", "keyword", "ai-search-ops"],
      "description": "文章分类"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "maxItems": 10
    },
    "primaryKeyword": {
      "type": "string",
      "minLength": 2,
      "description": "主关键词，必须来自关键词库"
    },
    "secondaryKeywords": {
      "type": "array",
      "items": { "type": "string" },
      "description": "次关键词列表，认知型关键词放这里"
    },
    "articleMarkdown": {
      "type": "string",
      "minLength": 1500,
      "description": "完整文章正文 Markdown：H1、答案前置、TL;DR、表格、实操步骤、FAQ、来源与日期、Flyfus CTA"
    },
    "faqJson": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["question", "answer"],
        "properties": {
          "question": { "type": "string", "minLength": 4 },
          "answer": { "type": "string", "minLength": 10 }
        }
      }
    },
    "schemaJsonLd": {
      "type": "object",
      "description": "Article + FAQPage 的 JSON-LD 结构化数据"
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["title", "sourceName", "sourceUrl", "retrievedAt", "asOf", "sourceType", "sourceTrust"],
        "properties": {
          "title": { "type": "string", "description": "被引用内容的标题" },
          "sourceName": { "type": "string", "description": "来源名称，对应 sources.yaml 中的 name" },
          "sourceUrl": { "type": "string", "pattern": "^https?://", "description": "来源 URL" },
          "retrievedAt": { "type": "string", "description": "抓取时间 ISO 8601" },
          "asOf": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$", "description": "信息截止日期 YYYY-MM-DD" },
          "sourceType": {
            "type": "string",
            "enum": ["official", "industry", "community", "tool_blog", "chinese_industry", "search"],
            "description": "来源类型"
          },
          "sourceTrust": {
            "type": "string",
            "enum": ["primary_fact", "needs_cross_check", "discovery_only"],
            "description": "来源信任级别：primary_fact=可作一手事实；needs_cross_check=需二次核查；discovery_only=仅选题线索"
          }
        }
      }
    },
    "internalLinks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["anchorText", "targetSlug", "reason"],
        "properties": {
          "anchorText": { "type": "string", "minLength": 2 },
          "targetSlug": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
          "reason": { "type": "string", "minLength": 4, "description": "为什么链接到这篇（主题相关性）" }
        }
      }
    },
    "flyfusCta": {
      "type": "string",
      "minLength": 10,
      "description": "文末 CTA，1-2 句，语气克制"
    }
  }
}
